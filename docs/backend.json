
{
  "entities": {
    "ClinicProfile": {
      "title": "ClinicProfile",
      "type": "object",
      "description": "Represents the dental clinic's profile and settings.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Patient": {
      "title": "Patient",
      "type": "object",
      "description": "Represents a patient in the dental clinic.",
      "properties": {
        "id": { "type": "string" },
        "clinicId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clinicId", "name", "phone"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled dental appointment.",
      "properties": {
        "id": { "type": "string" },
        "clinicId": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "attended", "no-show", "cancelled"] },
        "treatment": { "type": "string" }
      },
      "required": ["id", "clinicId", "patientId", "dateTime", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/clinics/{clinicId}",
        "definition": {
          "entityName": "ClinicProfile",
          "schema": { "$ref": "#/backend/entities/ClinicProfile" },
          "description": "Top-level clinic profile."
        }
      },
      {
        "path": "/clinics/{clinicId}/patients/{patientId}",
        "definition": {
          "entityName": "Patient",
          "schema": { "$ref": "#/backend/entities/Patient" },
          "description": "Patients belonging to a clinic."
        }
      },
      {
        "path": "/clinics/{clinicId}/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": { "$ref": "#/backend/entities/Appointment" },
          "description": "Appointments for a specific clinic."
        }
      }
    ]
  }
}
