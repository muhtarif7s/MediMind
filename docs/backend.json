
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the user's local profile and application settings within MediMind.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity (Auth UID)."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "language": {
          "type": "string",
          "description": "Preferred language ('en' or 'ar').",
          "format": "language"
        },
        "theme": {
          "type": "string",
          "description": "Visual theme ('light' or 'dark')."
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Whether push/local notifications are enabled."
        }
      },
      "required": [
        "id",
        "name",
        "language"
      ]
    },
    "Medicine": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Medicine",
      "type": "object",
      "description": "Represents a medication being managed.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "dosageAmount": {
          "type": "number"
        },
        "dosageUnit": {
          "type": "string"
        },
        "times": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isActive": {
          "type": "boolean"
        },
        "remainingQuantity": {
          "type": "number"
        },
        "totalQuantity": {
          "type": "number"
        },
        "refillThreshold": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "userId",
        "name",
        "isActive"
      ]
    },
    "DoseLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DoseLog",
      "type": "object",
      "description": "Records a single dose event.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "User ID for collection group query authorization."
        },
        "medicationId": {
          "type": "string"
        },
        "scheduledTime": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["taken", "skipped", "missed", "pending"]
        },
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "medicationId",
        "scheduledTime",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User profile data."
        }
      },
      {
        "path": "/users/{userId}/medicines/{medicineId}",
        "definition": {
          "entityName": "Medicine",
          "schema": {
            "$ref": "#/backend/entities/Medicine"
          },
          "description": "User's medications."
        }
      },
      {
        "path": "/users/{userId}/medicines/{medicineId}/doseLogs/{doseLogId}",
        "definition": {
          "entityName": "DoseLog",
          "schema": {
            "$ref": "#/backend/entities/DoseLog"
          },
          "description": "Log of doses taken or skipped for a medicine."
        }
      }
    ],
    "reasoning": "We use a hierarchical structure with denormalized userId in subcollections to support Authorization Independence and secure Collection Group queries for dose history."
  }
}
