{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user-specific settings, roles, and preferences.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["doctor", "patient", "admin"], "default": "doctor" },
        "phone": { "type": "string" },
        "fcmToken": { "type": "string", "description": "Firebase Cloud Messaging token for push notifications." },
        "language": { "type": "string", "default": "ar" },
        "theme": { "type": "string", "default": "light" },
        "notificationsEnabled": { "type": "boolean", "default": true },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "role", "createdAt"]
    },
    "Patient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Patient",
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "age": { "type": "number", "minimum": 0 },
        "clinicId": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "clinicId", "createdAt"]
    },
    "PatientRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PatientRecord",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["x-ray", "prescription", "report", "other"] },
        "fileData": { "type": "string", "description": "Base64 encoded file or image data." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "fileData", "createdAt"]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "properties": {
        "clinicId": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "attended", "no-show", "cancelled"] },
        "treatment": { "type": "string" }
      },
      "required": ["clinicId", "dateTime", "status"]
    },
    "Medication": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Medication",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "dosageAmount": { "type": "number" },
        "dosageUnit": { "type": "string" },
        "times": { "type": "array", "items": { "type": "string" } },
        "totalQuantity": { "type": "number" },
        "remainingQuantity": { "type": "number" },
        "refillThreshold": { "type": "number" }
      },
      "required": ["userId", "name", "dosageAmount", "totalQuantity", "remainingQuantity"]
    },
    "DoseLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DoseLog",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "medicationId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "taken", "skipped", "missed"] },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "recordedAt": { "type": "string", "format": "date-time" },
        "takenAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "medicationId", "status", "scheduledTime", "recordedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles with role-based access."
    },
    "/users/{userId}/patients/{patientId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Clinical patients."
    },
    "/users/{userId}/patients/{patientId}/records/{recordId}": {
      "schema": { "$ref": "#/backend/entities/PatientRecord" },
      "description": "Medical records for patients (X-rays, reports)."
    },
    "/users/{userId}/appointments/{appId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Clinical appointments."
    },
    "/users/{userId}/medicines/{medicineId}": {
      "schema": { "$ref": "#/backend/entities/Medication" },
      "description": "User medications."
    },
    "/users/{userId}/doseLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/DoseLog" },
      "description": "History of medication adherence."
    }
  }
}