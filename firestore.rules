rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Collection Group Rules (Must be top-level for queries)
    // This allows query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      // For collection group queries, we authorize based on the userId field.
      // We allow list operations if the query is filtered by the user's own ID.
      // We allow get operations if the document itself belongs to the user.
      allow read: if isSignedIn() && (
        (resource == null) || // Allow query evaluation
        (resource.data.userId == request.auth.uid)
      );
      
      // Write operations
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 2. User Profile & Hierarchical Rules
    match /users/{userId} {
      // Users can only read/write their own profile and everything underneath it.
      allow read, write: if isOwner(userId);

      // Recursive match for all subcollections under a user
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}