rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    // 1. Collection Group Rules (Critical for dose history sync)
    // Allows query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{logId} {
      // For read/update/delete, ensure the document belongs to the authenticated user via userId field.
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // For create, ensure the incoming data userId matches the authenticated user.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // 2. User Profile & Hierarchical Rules
    // This allows users to access their own branch of the database (profile, medicines, etc.)
    match /users/{userId} {
      // Manage own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Manage own medications subcollection
      match /medicines/{medicineId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        // Manage own doseLogs via direct path (redundant but safe)
        match /doseLogs/{logId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
  }
}