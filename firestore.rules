
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Collection Group rules for 'doseLogs'
    // This allows query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      // Allow read if the user is signed in and the document belongs to them.
      // We check the 'userId' field which is used in the collection group query filter.
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        // Fallback for hierarchical check if the field is missing (though it should be there)
        (path.size() >= 2 && path[0] == "users" && path[1] == request.auth.uid)
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        (path.size() >= 2 && path[0] == "users" && path[1] == request.auth.uid)
      );
      
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (path.size() >= 2 && path[0] == "users" && path[1] == request.auth.uid)
      );
    }

    // User Profile & Hierarchical Rules
    match /users/{userId} {
      // Users can only read/write their own profile and everything underneath it.
      allow read, write: if isOwner(userId);

      // Nested collections benefit from the parent userId match
      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);

        match /doseLogs/{doseLogId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
