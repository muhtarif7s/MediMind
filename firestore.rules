rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * 1. Collection Group Rules for doseLogs
     * Allows any authenticated user to read and write to any document 
     * in a collection named 'doseLogs' anywhere in the database.
     */
    match /{path=**}/doseLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    /**
     * 2. Individual User Document Rules
     * Ensures users can only access their own top-level profile document.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      /**
       * 3. Subcollection Rules
       * Allows the user full access to their own sub-collections (medicines, etc.)
       */
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}