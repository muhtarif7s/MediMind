rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * 1. Collection Group Rules for doseLogs
     * These rules authorize queries across all 'doseLogs' subcollections globally.
     * This is required for fetching medication history across different medications.
     */
    match /{path=**}/doseLogs/{logId} {
      // Allow reading and writing existing logs if the user matches
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Explicitly allow creating new logs with owner validation
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    /**
     * 2. Hierarchical User Rules
     * Allows users full access to their own branch of the database.
     */
    match /users/{userId} {
      // Allow user to read/write their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow user to read/write any subcollection (like medicines)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}