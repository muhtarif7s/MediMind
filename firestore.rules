
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for mobile-first PWA with collection group support.
     * Updated to fix collection group permission errors for dose history.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Collection Group rules for 'doseLogs'
    // Essential for: query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      // Allow list and get if the user owns the document
      // We check both the denormalized field and the path hierarchy for robustness
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (path.size() >= 2 && path[1] == request.auth.uid)
      );
      
      // For creating a new dose log
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
      );
      
      // For updating or deleting an existing dose log
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid
      );
    }

    // User Profile & Hierarchical Rules
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Medicine Rules
      match /medicines/{medicineId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        // Nested DoseLog Rules (direct access)
        match /doseLogs/{doseLogId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
  }
}
