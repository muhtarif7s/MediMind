
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Collection Group rules for 'doseLogs'
    // Required for query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      // Allow reading and listing if the document belongs to the signed-in user.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow creation if the new document identifies the current user.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Allow updates/deletes if the existing document belongs to the user.
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // User Profile & Hierarchical Rules
    match /users/{userId} {
      // Users can only read/write their own profile and everything underneath it.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Nested collections benefit from the parent userId match
      match /medicines/{medicineId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        match /doseLogs/{doseLogId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
  }
}
