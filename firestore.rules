
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Collection Group Rules
    // Allow any authenticated user to read/write all doseLogs anywhere
    match /{path=**}/doseLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid != null;
    }

    // 2. Personal User Rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 3. Clinic Management Rules
    match /clinics/{clinicId} {
      allow read, write: if request.auth != null && request.auth.uid == clinicId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == clinicId;
      }
    }
  }
}
