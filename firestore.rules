rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Collection Group Rules (Must be top-level for queries)
    // This allows query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{logId} {
      // For collection group queries, we authorize based on the userId field.
      // resource.data represents the existing document for read/update/delete
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // request.resource.data represents the document being created
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // 2. User Profile & Hierarchical Rules
    match /users/{userId} {
      // Users can only read/write their own profile and everything underneath it.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Recursive match for all subcollections under a user
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}