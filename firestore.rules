
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for mobile-first PWA with collection group support.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Collection Group rules for 'doseLogs'
    // This is required for query(collectionGroup(db, 'doseLogs'), where('userId', '==', user.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      // Allow creation of profile if the user is signed in as that ID
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Medicine Rules
      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);

        // Nested DoseLog Rules (for direct document access)
        match /doseLogs/{doseLogId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
