
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Collection Group rules for 'doseLogs'
    // This allows: query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      // For queries (list), the rule must be statically verifiable by the query filters.
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // For single document access (get), we can check both the data and the path.
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (path.size() >= 4 && path[1] == request.auth.uid)
      );
      
      // Allow creation if the data identifies the current user.
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
      );
      
      // Allow updates/deletes if the existing document belongs to the user.
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid
      );
    }

    // User Profile & Hierarchical Rules
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Medicine Rules
      match /medicines/{medicineId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        // Nested DoseLog Rules (direct subcollection access)
        match /doseLogs/{doseLogId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
  }
}
