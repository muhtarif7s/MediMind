rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. DoseLogs Collection Group — أي مستخدم مسجل دخول يقدر يقرأ ويكتب
    match /{path=**}/doseLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    // 2. Users Collection — كل مستخدم يقدر يقرأ ويكتب بياناته فقط
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 3. Clinics Collection — كل clinic يقدر يقرأ ويكتب بياناته فقط
    match /clinics/{clinicId} {
      allow read, write: if request.auth != null && request.auth.uid == clinicId;
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == clinicId;
      }
    }

  }
}