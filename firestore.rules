rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * 1. Collection Group Rules
     * These rules authorize queries across all 'doseLogs' subcollections globally.
     */
    match /{path=**}/doseLogs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    /**
     * 2. Hierarchical User Rules
     * Allows users full access to their own branch of the database.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}