
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // --- Collection Group Rules ---

    /**
     * @description Rules for querying dose logs across all medications using collectionGroup.
     * Required for history and adherence tracking.
     */
    match /{path=**}/doseLogs/{doseLogId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- User Scoped Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /patients/{patientId} {
        allow read, write: if isOwner(userId);
      }

      match /appointments/{appointmentId} {
        allow read, write: if isOwner(userId);
      }

      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);

        match /doseLogs/{doseLogId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Legacy paths from previous version (if still used by older logic)
      match /doses/{doseId} {
        allow read, write: if isOwner(userId);
      }
      
      match /doseLogs/{doseLogId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
