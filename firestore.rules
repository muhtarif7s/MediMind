rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * 1. Collection Group Rules
     * These rules authorize queries across all 'doseLogs' subcollections globally.
     * The userId check must match the .where('userId', '==', uid) filter in the code.
     */
    match /{path=**}/doseLogs/{logId} {
      // Authorize reads (get/list) for existing documents
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Authorize writes (create/update/delete)
      allow write: if request.auth != null && 
        (request.method == 'create' 
          ? request.resource.data.userId == request.auth.uid 
          : resource.data.userId == request.auth.uid);
    }

    /**
     * 2. Hierarchical User Rules
     * Allows users full access to their own branch of the database.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Automatically authorize all subcollections under the user
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}