
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Allow collection group queries for doseLogs.
    // This is critical for the history query in store.ts.
    // We check both the denormalized userId field and the path segments.
    match /{allPaths=**}/doseLogs/{doseLogId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (allPaths.size() >= 2 && allPaths[0] == 'users' && allPaths[1] == request.auth.uid)
      );
      allow write: if isSignedIn() && (
        (request.resource != null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        (allPaths.size() >= 2 && allPaths[0] == 'users' && allPaths[1] == request.auth.uid)
      );
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      match /medicines/{medicineId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);

        // Subcollection rules for direct document access
        match /doseLogs/{doseLogId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
