
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for mobile-first PWA with collection group support.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Collection Group rules for 'doseLogs'
    // This is required for query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{prefix=**}/doseLogs/{doseLogId} {
      // Allow list/get if the document belongs to the user (via userId field or path)
      allow list, get: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (prefix.size() >= 2 && prefix[1] == request.auth.uid)
      );
      // Allow mutations only if the user owns the record
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      // Medicine Rules
      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);

        // Nested DoseLog Rules (for direct document access)
        match /doseLogs/{doseLogId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
