
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clinics/{clinicId} {
      allow read, write: if request.auth != null && request.auth.uid == clinicId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == clinicId;
      }
    }
  }
}
