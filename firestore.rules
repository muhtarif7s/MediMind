
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Collection Group rules for 'doseLogs'
    // This allows query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      // For collection group queries, the rules must allow 'list' if the query 
      // is constrained by a filter that matches the user's ID.
      allow read: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
      );
      
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid
      );
    }

    // User Profile & Hierarchical Rules
    match /users/{userId} {
      // Users can only read/write their own profile and everything underneath it.
      allow read, write: if isOwner(userId);

      // Nested collections benefit from the parent userId match
      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);

        match /doseLogs/{doseLogId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
