
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Clinic Management Rules
    match /clinics/{clinicId} {
      allow read, write: if request.auth != null && request.auth.uid == clinicId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == clinicId;
      }
    }

    // 2. Personal User Rules (for Medication/MediMind features)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /medicines/{medicineId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        match /doseLogs/{logId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // 3. Global Collection Group Rules (for history/stats queries)
    match /{path=**}/doseLogs/{logId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && (request.resource.data.userId == request.auth.uid);
    }
  }
}
