
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules ---
    match /{path=**}/doseLogs/{doseLogId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- User Scoped Rules ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);

        match /doseLogs/{doseLogId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /patients/{patientId} {
        allow read, write: if isOwner(userId);
      }

      match /appointments/{appointmentId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Clinic Scoped Rules (Settings) ---
    match /clinics/{clinicId} {
      allow read, write: if isOwner(clinicId);
    }

    // Default deny
  }
}
