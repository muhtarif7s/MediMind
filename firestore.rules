rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MediMind Security Rules
     * Optimized for collection group queries and hierarchical user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Collection Group Rules (Must be top-level for queries)
    // This allows query(collectionGroup(db, 'doseLogs'), where('userId', '==', auth.uid))
    match /{path=**}/doseLogs/{doseLogId} {
      // For collection group queries, the 'resource' variable represents documents in the query result.
      // We authorize based on the denormalized userId field which must match the filter.
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // For direct gets via path
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        path[1] == request.auth.uid // Path segments: /users/{userId}/medicines/{medId}/doseLogs/{logId}
      );
      
      // Write operations
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 2. User Profile & Hierarchical Rules
    match /users/{userId} {
      // Users can only read/write their own profile and everything underneath it.
      allow read, write: if isOwner(userId);

      // Nested collections benefit from the parent userId match
      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);

        match /doseLogs/{doseLogId} {
          // Fallback path-based access
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}